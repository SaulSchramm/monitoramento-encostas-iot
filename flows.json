    },
    {
        "id": "gerador_sensor_virtual",
        "type": "inject",
        "z": "fluxo_encostas_virtual",
        "name": "Simular Leitura do Solo (2s)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "2",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
