        "y": 140,
        "wires": [
            [
                "transmissao_mqtt_out"
            ]
        ]
    },
    {
        "id": "transmissao_mqtt_out",
        "type": "mqtt out",
        "z": "fluxo_encostas_virtual",
        "name": "Publish (Nuvem MQTT)",
        "topic": "encostas/sensor/dados",
        "qos": "0",
        "retain": "false",
        "respTopic": "",
        "contentType": "",
        "userProps": "",
        "correl": "",
        "expiry": "",
        "broker": "broker_mackenzie",
        "x": 480,
        "y": 140,
        "wires": []
    },
    {
        "id": "recepcao_mqtt_in",
        "type": "mqtt in",
        "z": "fluxo_encostas_virtual",
        "name": "Subscribe (Defesa Civil)",
        "topic": "encostas/sensor/dados",
        "qos": "0",
        "datatype": "auto-detect",
        "broker": "broker_mackenzie",
        "inputs": 0,
        "x": 180,
        "y": 260,
        "wires": [
            [
                "logica_decisao"
            ]
        ]
    },
    {
        "id": "logica_decisao",
        "type": "function",
        "z": "fluxo_encostas_virtual",
        "name": "Algoritmo de Risco",
        "func": "var inclinacao = parseInt(msg.payload);\nvar status = \"NORMAL\";\n\nif (inclinacao >= 5 && inclinacao <= 12) {\n    status = \"ATENÇÃO\";\n} else if (inclinacao > 12) {\n    status = \"PERIGO\";\n}\n\nmsg.payload = {\n    \"graus\": inclinacao,\n    \"status\": status\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 260,
        "wires": [
            [
                "debug_tela",
                "separador_dados"
            ]
        ]
    },
    {
        "id": "debug_tela",
        "type": "debug",
        "z": "fluxo_encostas_virtual",
        "name": "Visualizar Mensagens",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 720,
        "y": 260,
        "wires": []
    },
    {
        "id": "node_grafico_linha",
        "type": "ui_chart",
